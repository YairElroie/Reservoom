<Window x:Class="Reservoom.Views.InfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Info"
        SizeToContent="Height"
        MaxHeight="420"
        Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="#F0F8FF" CornerRadius="10" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.2" ShadowDepth="0"/>
        </Border.Effect>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="&#xE946;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="40"
                       Foreground="#2196F3"
                       HorizontalAlignment="Center"
                       AutomationProperties.Name=""/>
            <TextBlock x:Name="TitleText"
                       Text="Information"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1A1A2E"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,5"/>
            <TextBlock x:Name="MessageText"
                       Text="Here is some information for you."
                       FontSize="13"
                       Foreground="#666666"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="280"/>
            <Button Content="OK"
                    Width="90"
                    Margin="0,20,0,0"
                    Padding="10,6"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OkButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Shadow"
                                            Background="#1565C0"
                                            CornerRadius="6">
                                        <Border x:Name="Face"
                                                Background="#2196F3"
                                                CornerRadius="6"
                                                Margin="0,0,0,4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White"/>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Face" Property="Background" Value="#1976D2"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Face" Property="Margin" Value="0,4,0,0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</Window>
